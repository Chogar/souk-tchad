API_BASE_URL=http://localhost:3000/api

# Google Sign-In (Console Google Cloud → Identifiants)
# iOS : client « Application iOS » (bundle com.hassanechogar.souktchad)
GOOGLE_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Web : même ID que GOOGLE_CLIENT_ID dans backend/.env
GOOGLE_SERVER_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
