<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  1. Console Firebase → Ajouter une app iOS (bundle: com.hassanechogar.souktchad)
  2. Télécharger GoogleService-Info.plist
  3. Copier vers ios/Runner/GoogleService-Info.plist (sans .example)
  4. Xcode → Signing & Capabilities → Push Notifications
-->
<plist version="1.0">
<dict>
	<key>API_KEY</key>
	<string>YOUR_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>YOUR_SENDER_ID</string>
	<key>PROJECT_ID</key>
	<string>YOUR_PROJECT_ID</string>
	<key>BUNDLE_ID</key>
	<string>com.hassanechogar.souktchad</string>
</dict>
</plist>
