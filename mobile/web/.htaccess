# Flutter web SPA — souk.experiencetech-td.com
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>
Options -Indexes
<IfModule mod_headers.c>
  # Ressources statiques immuables (polices, images, wasm)
  <FilesMatch "\.(wasm|woff2?|ttf|otf|png|jpg|jpeg|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # JS/CSS sans hash dans le nom : revalider à chaque déploiement (304 si inchangé)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "^(index\.html|flutter_service_worker\.js|manifest\.json|version\.json)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
