PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=souk_tchad
DATABASE_PASSWORD=souk_tchad_dev
DATABASE_NAME=souk_tchad

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth (Console Google Cloud)
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Uploads
UPLOAD_DIR=uploads
MAX_LISTINGS_FREE_PLAN=3

# Gmail SMTP (validation e-mail à l'inscription)
# Mot de passe d'application : https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=Souk Tchad <votre@gmail.com>
# URL publique du backend (lien dans l'e-mail Gmail)
APP_URL=http://localhost:3000

# Gemini AI (plan gratuit)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_RPM_LIMIT=15

# Firebase FCM (Console Firebase → Paramètres → Comptes de service)
# + mobile/ios/Runner/GoogleService-Info.plist
# + mobile/android/app/google-services.json
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
