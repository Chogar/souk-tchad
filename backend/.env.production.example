# Copier vers .env sur le serveur LWS (ne jamais committer .env)
NODE_ENV=production
PORT=3000

# PostgreSQL (cPanel → PostgreSQL Databases)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=c2748744c_usouktchad
DATABASE_PASSWORD=REMPLACER_MOT_DE_PASSE_PG
DATABASE_NAME=c2748744c_souktchad

# JWT — générer une chaîne longue aléatoire (64+ caractères)
JWT_SECRET=REMPLACER_PAR_UNE_CLE_LONGUE_ET_ALEATOIRE
JWT_EXPIRES_IN=7d

# CORS — origines autorisées (virgules)
CORS_ORIGINS=https://souk.experiencetech-td.com,https://www.experiencetech-td.com,https://experiencetech-td.com

# URL publique de l'API Souk (HTTPS). Ne pas utiliser apisouk.* = Expérience Tech.
# Pages légales : ${APP_URL}/legal/privacy.html
APP_URL=https://apisouktchad.experiencetech-td.com

# Google OAuth (Console Google Cloud → identifiants Web)
GOOGLE_CLIENT_ID=votre-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=votre-id-ios.apps.googleusercontent.com

# Uploads
UPLOAD_DIR=uploads
MAX_LISTINGS_FREE_PLAN=5

# SMTP — Gmail (OTP inscription) OU boîte mail LWS
# Option A — Gmail (mot de passe d'application) :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM=Souk Tchad <votre@gmail.com>
# Option B — boîte LWS :
SMTP_HOST=mail.experiencetech-td.com
SMTP_PORT=587
SMTP_USER=noreply@experiencetech-td.com
SMTP_PASS=mot_de_passe_boite_mail
SMTP_FROM=Souk Tchad <noreply@experiencetech-td.com>

# Paiements Mobile Money (manuel)
# mode: manual | disabled
PAYMENT_MODE=manual
PAYMENT_WEBHOOK_SECRET=REMPLACER_SECRET_CONFIRMATION_PAIEMENT
PAYMENT_MOMO_NUMBER=+23566000000
PAYMENT_MOMO_LABEL=Souk Tchad

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_RPM_LIMIT=15

# Firebase FCM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
